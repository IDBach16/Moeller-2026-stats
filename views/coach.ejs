<%- include('partials/header', { title: 'Coach Dashboard - Moeller Baseball' }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0">
    <%= config.season_year %> Moeller Crusaders
    <small class="text-muted" id="record-display">
      Record: <span id="record-text"><%= config.wins %>-<%= config.losses %>-<%= config.ties %></span>
      <button class="btn btn-sm btn-outline-secondary ms-1 py-0 px-1" id="editRecordBtn" title="Edit Record" style="font-size:11px;">✏️</button>
    </small>
    <span id="record-edit" style="display:none;">
      <input type="number" id="edit-wins" value="<%= config.wins %>" min="0" style="width:50px;" class="form-control form-control-sm d-inline-block">
      -
      <input type="number" id="edit-losses" value="<%= config.losses %>" min="0" style="width:50px;" class="form-control form-control-sm d-inline-block">
      -
      <input type="number" id="edit-ties" value="<%= config.ties %>" min="0" style="width:50px;" class="form-control form-control-sm d-inline-block">
      <button class="btn btn-sm btn-success py-0 px-2 ms-1" id="saveRecordBtn">Save</button>
      <button class="btn btn-sm btn-outline-secondary py-0 px-2" id="cancelRecordBtn">Cancel</button>
    </span>
  </h4>
  <div>
    <a href="/coach/print" class="btn btn-sm btn-outline-secondary">Print Stats</a>
    <a href="/api/backup" class="btn btn-sm btn-outline-success ms-1">Download Backup</a>
    <a href="/api/export/csv" class="btn btn-sm btn-outline-primary ms-1">Export CSV</a>
  </div>
</div>

<ul class="nav nav-tabs" id="statTabs" role="tablist">
  <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tab-gcl-season" data-season="gcl-season">Season Stats</a></li>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-gcl-games" data-season="gcl-games">Game Stats</a></li>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-exhibition" data-season="exhibition">Exhibition</a></li>
</ul>

<div class="tab-content mt-3" id="statTabContent">
  <!-- Total / Regular / Postseason tabs share same structure -->
  <!-- GCL Season Stats Tab -->
  <div class="tab-pane fade show active" id="tab-gcl-season">
    <div class="stat-loading text-center py-4"><div class="spinner-border text-secondary"></div></div>
    <div class="stat-content" style="display:none">
      <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-sm btn-outline-success" id="gclRefreshBtn">Refresh from GCL</button>
      </div>
      <h5>Batting</h5>
      <div class="table-responsive">
        <table class="table table-sm table-striped table-hover stat-table batting-table gcl-table" id="gclBattingTable">
          <thead class="table-dark"></thead><tbody></tbody><tfoot class="table-secondary"></tfoot>
        </table>
      </div>
      <h5 class="mt-4">Pitching</h5>
      <div class="table-responsive">
        <table class="table table-sm table-striped table-hover stat-table pitching-table gcl-table" id="gclPitchingTable">
          <thead class="table-dark"></thead><tbody></tbody><tfoot class="table-secondary"></tfoot>
        </table>
      </div>
    </div>
  </div>

  <!-- GCL Game Stats Tab -->
  <div class="tab-pane fade" id="tab-gcl-games">
    <div class="stat-loading text-center py-4"><div class="spinner-border text-secondary"></div></div>
    <div class="stat-content" style="display:none">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <small class="text-muted">Individual game boxscores from GCL</small>
        <button class="btn btn-sm btn-outline-success" id="gclRefreshBtn2">Refresh from GCL</button>
      </div>
      <div class="accordion" id="gclGamesAccordion"></div>
    </div>
  </div>

  <!-- Exhibition Tab (manual entry) -->
  <div class="tab-pane fade" id="tab-exhibition">
    <div class="stat-loading text-center py-4"><div class="spinner-border text-secondary"></div></div>
    <div class="stat-content" style="display:none">
      <h5>Batting <span class="badge bg-secondary">Exhibition</span></h5>
      <div class="table-responsive stat-table-wrap">
        <table class="table table-sm table-striped table-hover stat-table batting-table" data-sort-default="avg">
          <thead class="table-dark sticky-top"></thead><tbody></tbody><tfoot class="table-secondary"></tfoot>
        </table>
      </div>
      <h5 class="mt-4">Pitching <span class="badge bg-secondary">Exhibition</span></h5>
      <div class="table-responsive stat-table-wrap">
        <table class="table table-sm table-striped table-hover stat-table pitching-table" data-sort-default="era">
          <thead class="table-dark sticky-top"></thead><tbody></tbody><tfoot class="table-secondary"></tfoot>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- GCL Edit Game Modal -->
<div class="modal fade" id="gclEditModal" tabindex="-1">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title">Edit Game <span id="gclEditTitle"></span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="gclEditGameId">
        <h6>Batting</h6>
        <div class="table-responsive">
          <table class="table table-sm table-striped" id="gclEditBattingTable">
            <thead class="table-dark"></thead>
            <tbody></tbody>
          </table>
        </div>
        <h6 class="mt-3">Pitching</h6>
        <div class="table-responsive">
          <table class="table table-sm table-striped" id="gclEditPitchingTable">
            <thead class="table-dark"></thead>
            <tbody></tbody>
          </table>
        </div>
        <div id="gclEditError" class="alert alert-danger mt-2" style="display:none"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="gclSaveEdit">Save Changes</button>
      </div>
    </div>
  </div>
</div>

<div id="sse-status" class="position-fixed bottom-0 end-0 m-3" style="display:none">
  <span class="badge bg-success">Live updates active</span>
</div>

<!-- Edit Game Modal -->
<div class="modal fade" id="editGameModal" tabindex="-1">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title">Edit Game <span id="editGameTitle"></span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="editGameId">
        <div class="row mb-3">
          <div class="col-md-4">
            <label class="form-label fw-bold">Opponent</label>
            <input type="text" class="form-control" id="editOpponent" placeholder="Opponent name">
          </div>
          <div class="col-md-4">
            <label class="form-label fw-bold">Home / Away</label>
            <select class="form-select" id="editHomeAway">
              <option value="home">Home</option>
              <option value="away">Away</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-bold">Result</label>
            <select class="form-select" id="editResult">
              <option value="W">Win</option>
              <option value="L">Loss</option>
              <option value="T">Tie</option>
            </select>
          </div>
        </div>
        <div class="row mb-3">
          <div class="col-md-6">
            <label class="form-label fw-bold">Season Type</label>
            <select class="form-select" id="editSeasonType">
              <option value="regular">Regular Season</option>
              <option value="postseason">Postseason</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold">Game Classification</label>
            <select class="form-select" id="editGameTag">
              <option value="conference">Conference</option>
              <option value="non_conference">Non-Conference</option>
              <option value="exhibition">Exhibition</option>
            </select>
          </div>
        </div>
        <div class="d-flex justify-content-between align-items-center">
          <h6 class="mb-0">Batting</h6>
          <div class="d-flex gap-2 align-items-center">
            <select class="form-select form-select-sm" id="addBatterSelect" style="width:200px">
              <option value="">Add player...</option>
            </select>
            <button type="button" class="btn btn-sm btn-outline-primary" id="addBatterBtn">+ Add</button>
          </div>
        </div>
        <div class="table-responsive mt-1">
          <table class="table table-sm table-striped" id="editBattingTable">
            <thead class="table-dark"></thead>
            <tbody></tbody>
          </table>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3">
          <h6 class="mb-0">Pitching</h6>
          <div class="d-flex gap-2 align-items-center">
            <select class="form-select form-select-sm" id="addPitcherSelect" style="width:200px">
              <option value="">Add player...</option>
            </select>
            <button type="button" class="btn btn-sm btn-outline-primary" id="addPitcherBtn">+ Add</button>
          </div>
        </div>
        <div class="table-responsive mt-1">
          <table class="table table-sm table-striped" id="editPitchingTable">
            <thead class="table-dark"></thead>
            <tbody></tbody>
          </table>
        </div>
        <div id="editError" class="alert alert-danger mt-2" style="display:none"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="saveEditGame">Save Changes</button>
      </div>
    </div>
  </div>
</div>

<script src="/js/coach.js"></script>
<script>
  document.getElementById('editRecordBtn').addEventListener('click', () => {
    document.getElementById('record-display').style.display = 'none';
    document.getElementById('record-edit').style.display = 'inline';
  });
  document.getElementById('cancelRecordBtn').addEventListener('click', () => {
    document.getElementById('record-edit').style.display = 'none';
    document.getElementById('record-display').style.display = '';
  });
  document.getElementById('saveRecordBtn').addEventListener('click', async () => {
    const wins = document.getElementById('edit-wins').value;
    const losses = document.getElementById('edit-losses').value;
    const ties = document.getElementById('edit-ties').value;
    const res = await fetch('/api/config', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ wins, losses, ties })
    });
    if (res.ok) {
      document.getElementById('record-text').textContent = `${wins}-${losses}-${ties}`;
      document.getElementById('edit-wins').value = wins;
      document.getElementById('edit-losses').value = losses;
      document.getElementById('edit-ties').value = ties;
      document.getElementById('record-edit').style.display = 'none';
      document.getElementById('record-display').style.display = '';
    }
  });
</script>
<%- include('partials/footer') %>
